{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist-main",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node"]
  },
  "include": [
    "main/**/*.ts", 
    "db/**/*.ts", 
    "packages/commands/**/*.ts", 
    "packages/shared/**/*.ts", 
    "shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "app",
    "components",
    "out",
    ".next"
  ]
}
